# API Keys for k-LLMmeans
# Copy this file to .env and fill in your actual keys
# The .env file is gitignored and will not be committed

# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
# Endpoint must be the resource root only, e.g. https://YOUR_RESOURCE.openai.azure.com
# (no trailing /openai or /v1 — those cause 404s on some calls)
AZURE_OPENAI_ENDPOINT=your_azure_openai_endpoint_here
AZURE_OPENAI_API_VERSION=2024-02-15-preview
# Deployment *name* for embeddings (text-embedding-3-small in Azure). Not your chat model.
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=your_embedding_deployment_name_here
# Optional: chat/completions deployment name (gpt-4o, etc.) — not used for embeddings
# AZURE_OPENAI_DEPLOYMENT=your_chat_deployment_name_here

# OpenAI API key (for GPT models and embeddings)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_KEY=your_openai_api_key_here

# Llama API key (for llama3.3-70b)
# Get your key from: https://llama-api.com/
LLAMA_KEY=your_llama_api_key_here

# DeepSeek API key (for deepseek-chat)
# Get your key from: https://platform.deepseek.com/
DEEPSEEK_KEY=your_deepseek_api_key_here

# Anthropic API key (for Claude models)
# Get your key from: https://console.anthropic.com/
CLAUDE_KEY=your_claude_api_key_here

# Note: You only need keys for the services you plan to use.
# For non-LLM experiments (vanilla k-means), you don't need any keys.
# For local embeddings (distilbert, e5-large, sbert), you don't need keys.
